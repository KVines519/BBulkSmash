# Copy this file to .env and fill in the values before running docker-compose.
# docker-compose will automatically load a .env file in the same directory.

# Required: Django secret key. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Required: Comma-separated list of origins you access the app from.
# Must include the scheme (http:// or https://) and host.
# Example: http://192.168.1.100,http://localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost

# Optional: Comma-separated list of allowed hostnames/IPs (defaults to * if not set).
# Example: 192.168.1.100,localhost
DJANGO_ALLOWED_HOSTS=*
